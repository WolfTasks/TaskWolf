# ===== Required =====
TW_JWT_SECRET=replace-with-a-secure-256-bit-random-string  # generate: openssl rand -base64 48

# ===== Database =====
TW_DB_USER=taskowolf
TW_DB_PASS=changeme

# ===== Application =====
TW_BASE_URL=https://yourdomain.com
TW_REGISTRATION_ENABLED=true          # Set to false after first admin registers
TW_ALLOWED_ORIGINS=https://yourdomain.com

# ===== Attachments =====
TW_ATTACHMENT_PATH=./data/attachments
TW_ATTACHMENT_MAX_SIZE=26214400       # 25 MB in bytes

# ===== SMTP (optional — leave blank to disable email) =====
TW_SMTP_HOST=
TW_SMTP_PORT=587
TW_SMTP_USER=
TW_SMTP_PASS=
TW_SMTP_FROM=TaskWolf <noreply@yourdomain.com>

# ===== IMAP / Email Ingestion (optional — leave disabled to skip) =====
TW_MAIL_IMAP_ENABLED=false
TW_MAIL_IMAP_HOST=imap.example.com
TW_MAIL_IMAP_USER=support@example.com
TW_MAIL_IMAP_PASS=changeme
TW_MAIL_IMAP_PORT=993
